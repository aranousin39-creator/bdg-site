<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Register - BDG Lottery</title>
  <link rel="stylesheet" href="/main/style.css">
</head>
<body>
  <h1>Register Page</h1>
  <p>Your invitation code is: <span id="code">Loading...</span></p>

  <script>
    // Get the invitation code from URL
    const urlParams = new URLSearchParams(window.location.search);
    const code = urlParams.get('invitationCode');
    document.getElementById('code').textContent = code ? code : "No code provided";
  </script>
</body>
</html>
